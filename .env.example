# =========================
# Supabase
# =========================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-or-secret-key

# =========================
# Password gates
# =========================
GUARD_ACCESS_PASSWORD=your-guard-password
LC_ACCESS_PASSWORD=your-lc-password
BEACH_ACCESS_PASSWORD=beach
BEACH_ADMIN_PASSWORD=DempDemp

# =========================
# Auth / sessions
# =========================
JWT_SECRET=generate-a-random-string-at-least-32-chars

# =========================
# Email notifications / Gmail API
# =========================
EMAIL_ENABLED=false
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/email/oauth/callback
GMAIL_SENDER_EMAIL=lberinde@cityofevanston.org
GMAIL_REFRESH_TOKEN=

# =========================
# Vector / CrewSense
# =========================
VECTOR_ENABLED=true
VECTOR_MODE=block
VECTOR_SYNC_WRITES_ENABLED=false
VECTOR_CLIENT_ID=your-crewsense-client-id
VECTOR_CLIENT_SECRET=your-crewsense-client-secret
VECTOR_API_BASE_URL=https://api.crewsense.com
VECTOR_DEBUG_SECRET=optional-local-debug-secret
